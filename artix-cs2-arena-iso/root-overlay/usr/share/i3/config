# ═══════════════════════════════════════════════════
# i3 Window Manager Configuration — artix-cs2-arena
# Minimal gaming-focused setup
# ═══════════════════════════════════════════════════

# ─── Mod key (Windows key) ───
set $mod Mod4

# ─── Font ───
font pango:Hack 10

# ─── Floating modifier ───
floating_modifier $mod

# ─── Terminal ───
bindsym $mod+Return exec alacritty

# ─── Launcher ───
bindsym $mod+d exec rofi -show drun -show-icons

# ─── Window management ───
bindsym $mod+q kill
bindsym $mod+f fullscreen toggle
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Split+H split h
bindsym $mod+Split+V split v
bindsym $mod+space focus mode_toggle
bindsym $mod+Shift+space floating toggle

# ─── Workspace names ───
set $ws1 "1: Steam"
set $ws2 "2: CS2"
set $ws3 "3: Discord"
set $ws4 "4: Web"
set $ws5 "5: Term"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5

# ─── Layout ───
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# ─── Reload/Restart ───
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -b 'Yes' 'i3-msg exit'"

# ─── System shortcuts ───
bindsym $mod+Shift+s exec --no-startup-id "systemctl suspend || loginctl suspend"
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle

# ─── Resize mode ───
mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# ─── Auto-start applications ───
exec --no-startup-id nitrogen --restore
exec --no-startup-id volumeicon
exec --no-startup-id polychromatic-helper &
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# ─── Window rules ───
# CS2 — fullscreen on workspace 2
for_window [class="steam_app_730"] move to workspace $ws2, fullscreen enable

# Steam — workspace 1
for_window [class="Steam"] move to workspace $ws1

# Discord — workspace 3
for_window [class="discord"] move to workspace $ws3

# Gaming tools
for_window [class="MangoHud"] floating enable

# ─── Bar ───
bar {
    status_command i3status
    position top
    font pango:Hack 9
    colors {
        background #1a1a2e
        statusline #e0e0e0
        focused_workspace #16213e #0f3460 #e94560
        active_workspace #1a1a2e #16213e #e0e0e0
        inactive_workspace #1a1a2e #1a1a2e #888888
    }
}

# ─── Gaps (minimal) ───
gaps inner 4
gaps outer 2
smart_gaps on
smart_borders on

# ─── Colors ───
client.focused          #0f3460 #16213e #e0e0e0 #e94560 #0f3460
client.focused_inactive #1a1a2e #1a1a2e #888888 #1a1a2e #1a1a2e
client.unfocused        #1a1a2e #1a1a2e #888888 #1a1a2e #1a1a2e
client.urgent           #e94560 #e94560 #ffffff #e94560 #e94560
